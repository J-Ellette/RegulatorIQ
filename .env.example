# RegulatorIQ Environment Variables
# Copy this file to .env and fill in your values

# Database
DB_USER=regulatoriq
DB_PASSWORD=your_secure_password_here

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Hugging Face
HUGGINGFACE_API_TOKEN=hf_your-huggingface-token-here

# Federal Register API
FEDERAL_REGISTER_API_KEY=your-federal-register-api-key

# FERC API
FERC_API_KEY=your-ferc-api-key

# Redis
REDIS_PASSWORD=your_redis_password_here

# Application
ASPNETCORE_ENVIRONMENT=Production
NODE_ENV=production

# JWT (if implementing auth)
JWT_SECRET=your-jwt-secret-key-minimum-32-characters
JWT_EXPIRY_HOURS=24

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ML Services
ML_SERVICES_PORT=8000

# Hangfire
HANGFIRE_WORKER_COUNT=5

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
