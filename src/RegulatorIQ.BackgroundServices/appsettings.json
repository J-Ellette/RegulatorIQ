{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=regulatoriq;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "MLServices": {
    "BaseUrl": "http://ml-services:8000"
  },
  "Monitoring": {
    "RequestTimeoutSeconds": 60,
    "federal": {
      "Sources": [ "federal_register", "ferc", "doe", "epa", "phmsa" ]
    },
    "state": {
      "Sources": [ "texas" ]
    }
  },
  "Analysis": {
    "Mode": "Auto"
  },
  "Hangfire": {
    "WorkerCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
