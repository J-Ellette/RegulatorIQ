{
  "ConnectionStrings": {
    // For local development only. Use environment variables or secrets management in production.
    "DefaultConnection": "Host=localhost;Port=5432;Database=regulatoriq;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "MLServices": {
    "BaseUrl": "http://localhost:8000"
  },
  "Monitoring": {
    "RequestTimeoutSeconds": 60,
    "federal": {
      "Sources": [ "federal_register", "ferc", "doe", "epa", "phmsa" ]
    },
    "state": {
      "Sources": [ "texas" ]
    }
  },
  "Analysis": {
    "Mode": "Auto"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000"
  },
  "Hangfire": {
    "WorkerCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
